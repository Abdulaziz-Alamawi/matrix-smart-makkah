# Matrix Smart Makkah — Web environment
# Copy to .env and adjust as needed.

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://matrix:matrix@localhost:5432/matrix_makkah?schema=public"

# ML microservice base URL (FastAPI + scikit-learn)
ML_SERVICE_URL="http://localhost:8000"
NEXT_PUBLIC_ML_SERVICE_URL="http://localhost:8000"

# App
NODE_ENV="development"
